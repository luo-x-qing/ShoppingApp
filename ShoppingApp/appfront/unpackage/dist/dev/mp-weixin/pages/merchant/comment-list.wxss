}

/* 统计卡片 */
.stats-card.data-v-ea970549 {
  display: flex;
  flex-wrap: wrap;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.stat-item.data-v-ea970549 {
  flex: 1;
  min-width: 16%;
  text-align: center;
  padding: 15rpx 0;
  border-radius: 12rpx;
  margin: 5rpx;
}
.stat-number.data-v-ea970549 {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
}
.stat-label.data-v-ea970549 {
