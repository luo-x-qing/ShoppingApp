<view class="container data-v-d4a6fad9"><view class="stats-bar data-v-d4a6fad9"><view class="stat-item data-v-d4a6fad9"><text class="stat-number data-v-d4a6fad9">{{a}}</text><text class="stat-label data-v-d4a6fad9">未读消息</text></view><view class="stat-item data-v-d4a6fad9"><text class="stat-number data-v-d4a6fad9">{{b}}</text><text class="stat-label data-v-d4a6fad9">对话数量</text></view><view class="stat-item data-v-d4a6fad9"><text class="clear-all data-v-d4a6fad9" bindtap="{{c}}">一键已读</text></view></view><scroll-view class="conversation-list data-v-d4a6fad9" scroll-y="true"><view wx:for="{{d}}" wx:for-item="conv" wx:key="q" class="conversation-item-wrapper data-v-d4a6fad9"><view class="delete-btn data-v-d4a6fad9" bindtap="{{conv.a}}"><text class="data-v-d4a6fad9">删除</text></view><view class="{{['conversation-item', 'data-v-d4a6fad9', conv.l && 'slide-left']}}" bindtouchstart="{{conv.m}}" bindtouchmove="{{conv.n}}" bindtouchend="{{conv.o}}" bindtap="{{conv.p}}"><view class="conv-avatar data-v-d4a6fad9"><view class="avatar-placeholder data-v-d4a6fad9">{{conv.b}}</view><view wx:if="{{conv.c}}" class="unread-dot data-v-d4a6fad9"></view></view><view class="conv-content data-v-d4a6fad9"><view class="conv-header data-v-d4a6fad9"><text class="conv-name data-v-d4a6fad9">{{conv.d}}</text><text class="conv-time data-v-d4a6fad9">{{conv.e}}</text></view><view class="conv-hotel data-v-d4a6fad9"><text class="hotel-name data-v-d4a6fad9">🏨 {{conv.f}}</text></view><view class="conv-preview data-v-d4a6fad9"><text wx:if="{{conv.g}}" class="preview-text data-v-d4a6fad9">用户：{{conv.h}}</text><text wx:else class="preview-text merchant-preview data-v-d4a6fad9">商家：{{conv.i}}</text></view></view><view wx:if="{{conv.j}}" class="conv-badge data-v-d4a6fad9"><text class="data-v-d4a6fad9">{{conv.k}}</text></view></view></view><view wx:if="{{e}}" class="empty-state data-v-d4a6fad9"><text class="empty-icon data-v-d4a6fad9">💬</text><text class="empty-text data-v-d4a6fad9">暂无客户消息</text><text class="empty-tip data-v-d4a6fad9">当有客户预订酒店后会自动显示在这里</text></view></scroll-view><view wx:if="{{f}}" class="chat-modal data-v-d4a6fad9" bindtap="{{r}}"><view class="modal-container data-v-d4a6fad9" catchtap="{{q}}"><view class="modal-header data-v-d4a6fad9"><view class="header-info data-v-d4a6fad9"><text class="modal-title data-v-d4a6fad9">{{g}}</text><text class="modal-hotel data-v-d4a6fad9">🏨 {{h}}</text></view><text class="modal-close data-v-d4a6fad9" bindtap="{{i}}">✕</text></view><scroll-view class="chat-messages data-v-d4a6fad9" scroll-y="true" scroll-into-view="msg-bottom" scroll-with-animation="{{true}}"><view wx:for="{{j}}" wx:for-item="msg" wx:key="e" class="message-item data-v-d4a6fad9"><view wx:if="{{msg.a}}" class="message-left data-v-d4a6fad9"><view class="message-avatar data-v-d4a6fad9"><view class="user-avatar data-v-d4a6fad9">{{msg.b}}</view></view><view class="message-bubble user-bubble data-v-d4a6fad9"><text class="data-v-d4a6fad9">{{msg.c}}</text></view></view><view wx:else class="message-right data-v-d4a6fad9"><view class="message-bubble merchant-bubble data-v-d4a6fad9"><text class="data-v-d4a6fad9">{{msg.d}}</text></view><view class="message-avatar data-v-d4a6fad9"><view class="merchant-avatar data-v-d4a6fad9">商</view></view></view></view><view class="data-v-d4a6fad9" id="msg-bottom"></view></scroll-view><view wx:if="{{k}}" class="quick-replies data-v-d4a6fad9"><scroll-view scroll-x="true" class="quick-scroll data-v-d4a6fad9"><view wx:for="{{l}}" wx:for-item="reply" wx:key="b" class="quick-reply-item data-v-d4a6fad9" bindtap="{{reply.c}}"><text class="data-v-d4a6fad9">{{reply.a}}</text></view></scroll-view></view><view class="chat-input-area data-v-d4a6fad9"><input class="chat-input data-v-d4a6fad9" placeholder="输入消息..." confirm-type="send" bindconfirm="{{m}}" value="{{n}}" bindinput="{{o}}"/><button class="send-btn data-v-d4a6fad9" bindtap="{{p}}">发送</button></view></view></view></view>