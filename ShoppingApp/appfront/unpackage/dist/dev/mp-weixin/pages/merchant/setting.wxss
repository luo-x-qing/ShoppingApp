
.container.data-v-794c7c1a {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}
.setting-list.data-v-794c7c1a {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}
.setting-section.data-v-794c7c1a {
  border-bottom: 20rpx solid #f5f5f5;
}
.section-title.data-v-794c7c1a {
  padding: 30rpx 30rpx 20rpx;
  font-size: 28rpx;
  color: #999;
  background-color: #fff;
}
.setting-item.data-v-794c7c1a {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
}
.setting-item.data-v-794c7c1a:active {
  background-color: #f9f9f9;
}
.item-label.data-v-794c7c1a {
  font-size: 30rpx;
  color: #333;
}
.item-right.data-v-794c7c1a {
  display: flex;
  align-items: center;
  gap: 15rpx;
}
.item-value.data-v-794c7c1a {
  font-size: 28rpx;
  color: #999;
  max-width: 400rpx;
  text-align: right;
}
.item-value.description.data-v-794c7c1a {
  max-width: 500rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.item-arrow.data-v-794c7c1a {
  font-size: 32rpx;
  color: #ccc;
}
.version-info.data-v-794c7c1a {
  padding: 40rpx;
  text-align: center;
}
.version-text.data-v-794c7c1a {
  font-size: 24rpx;
  color: #ccc;
}

/* 弹窗样式 */
.modal-mask.data-v-794c7c1a {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-container.data-v-794c7c1a {
  width: 85%;
  background-color: #fff;
  border-radius: 30rpx;
  overflow: hidden;
}
.modal-header.data-v-794c7c1a {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1px solid #eee;
}
.modal-title.data-v-794c7c1a {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}
.modal-close.data-v-794c7c1a {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}
.modal-body.data-v-794c7c1a {
  padding: 40rpx 30rpx;
}
.edit-input.data-v-794c7c1a {
  width: 100%;
  padding: 24rpx;
  border: 1px solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.edit-textarea.data-v-794c7c1a {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  border: 1px solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.modal-footer.data-v-794c7c1a {
  display: flex;
  padding: 20rpx 30rpx 40rpx;
  gap: 20rpx;
}
.cancel-btn.data-v-794c7c1a, .confirm-btn.data-v-794c7c1a {
  flex: 1;
  border-radius: 50rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: none;
}
.cancel-btn.data-v-794c7c1a {
  background-color: #f5f5f5;
  color: #666;
}
.confirm-btn.data-v-794c7c1a {
  background-color: #f0e68c;
  color: #333;
}
