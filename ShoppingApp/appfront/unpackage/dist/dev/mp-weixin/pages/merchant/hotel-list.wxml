<view class="container"><view class="header-bar"><view class="title">酒店管理</view><button class="add-btn" bindtap="{{a}}">+ 添加酒店</button></view><view class="hotel-list"><view wx:for="{{b}}" wx:for-item="hotel" wx:key="o" class="hotel-card"><image class="hotel-cover" src="{{hotel.a}}" mode="aspectFill"></image><view class="hotel-info"><text class="hotel-name">{{hotel.b}}</text><text class="hotel-address">📍 {{hotel.c}}</text><view class="hotel-stats"><text class="star-level">{{hotel.d}}</text><text class="price">¥{{hotel.e}}/晚</text></view><view class="hotel-status-row"><text class="status-label">状态：</text><text class="{{['status-value', hotel.g]}}">{{hotel.f}}</text><button class="status-toggle-btn" bindtap="{{hotel.i}}">{{hotel.h}}</button></view><view wx:if="{{hotel.j}}" class="hotel-category"><text class="category-tag">{{hotel.k}}</text></view></view><view class="hotel-actions"><button class="edit-btn" bindtap="{{hotel.l}}">编辑</button><button class="room-btn" bindtap="{{hotel.m}}">房型管理</button><button class="delete-btn" bindtap="{{hotel.n}}">删除</button></view></view></view><view wx:if="{{c}}" class="empty-state"><text>暂无酒店，点击上方按钮添加</text></view><view wx:if="{{d}}" class="loading"><text>加载中...</text></view><view wx:if="{{e}}" class="modal-mask" bindtap="{{D}}"><view class="modal-container" catchtap="{{C}}"><view class="modal-header"><text class="modal-title">{{f}}</text><text class="modal-close" bindtap="{{g}}">×</text></view><scroll-view class="modal-body" scroll-y><view class="form-item"><text class="label">酒店名称 <text class="required">*</text></text><input class="input" placeholder="请输入酒店名称" value="{{h}}" bindinput="{{i}}"/></view><view class="form-item"><text class="label">酒店分类 <text class="required">*</text></text><picker range="{{k}}" bindchange="{{l}}"><view class="picker">{{j}}</view></picker></view><view class="form-item"><text class="label">酒店地址 <text class="required">*</text></text><view class="address-row"><input class="input address-input" placeholder="请输入详细地址" value="{{m}}" bindinput="{{n}}"/><button class="map-btn" bindtap="{{o}}">🗺️ 百度地图选点</button></view></view><view class="form-item"><text class="label">星级 <text class="required">*</text></text><view class="star-box"><text wx:for="{{p}}" wx:for-item="i" wx:key="a" class="{{['star', i.b && 'active']}}" bindtap="{{i.c}}">★</text></view></view><view class="form-item"><text class="label">价格（元/晚） <text class="required">*</text></text><input class="input" type="digit" placeholder="请输入价格" value="{{q}}" bindinput="{{r}}"/></view><view class="form-item"><text class="label">总房间数</text><input class="input" type="number" placeholder="请输入总房间数" value="{{s}}" bindinput="{{t}}"/></view><view class="form-item"><text class="label">封面图</text><view class="upload-box" bindtap="{{x}}"><image wx:if="{{v}}" src="{{w}}" class="upload-image" mode="aspectFill"></image><view wx:else class="upload-placeholder"><text class="upload-icon">+</text><text class="upload-text">点击上传</text></view></view></view><view class="form-item"><text class="label">详情图（可多张）</text><view class="detail-upload-list"><view wx:for="{{y}}" wx:for-item="img" wx:key="c" class="detail-image-item"><image src="{{img.a}}" class="detail-image" mode="aspectFill"></image><text class="detail-delete" bindtap="{{img.b}}">×</text></view><view class="upload-btn" bindtap="{{z}}"><text class="upload-icon">+</text></view></view></view></scroll-view><view class="modal-footer"><button class="cancel-btn" bindtap="{{A}}">取消</button><button class="confirm-btn" bindtap="{{B}}">保存</button></view></view></view><view wx:if="{{E}}" class="modal-mask" bindtap="{{M}}"><view class="room-modal-container" catchtap="{{L}}"><view class="modal-header"><text class="modal-title">房型管理 - {{F}}</text><button class="add-room-btn" bindtap="{{G}}">+ 添加房型</button><text class="modal-close" bindtap="{{H}}">×</text></view><scroll-view class="modal-body" scroll-y><view class="room-list"><view wx:for="{{I}}" wx:for-item="room" wx:key="l" class="room-card"><view class="room-info"><text class="room-name">{{room.a}}</text><text class="room-desc">{{room.b}} | {{room.c}} | {{room.d}}</text><view wx:if="{{room.e}}" class="room-breakfast">🍳 {{room.f}}</view><view class="room-stats"><text class="room-price">¥{{room.g}}/晚</text><text class="room-stock">库存: {{room.h}}/{{room.i}}</text></view></view><view class="room-actions"><button class="room-edit-btn" bindtap="{{room.j}}">编辑</button><button class="room-delete-btn" bindtap="{{room.k}}">删除</button></view></view></view><view wx:if="{{J}}" class="empty-state"><text>暂无房型，点击上方按钮添加</text></view></scroll-view><view class="modal-footer"><button class="cancel-btn" bindtap="{{K}}">关闭</button></view></view></view><view wx:if="{{N}}" class="modal-mask" bindtap="{{am}}"><view class="room-form-container" catchtap="{{al}}"><view class="modal-header"><text class="modal-title">{{O}}</text><text class="modal-close" bindtap="{{P}}">×</text></view><scroll-view class="modal-body" scroll-y><view class="form-item"><text class="label">房型名称 <text class="required">*</text></text><input class="input" placeholder="如：大床房、双床房" value="{{Q}}" bindinput="{{R}}"/></view><view class="form-item"><text class="label">房间价格 <text class="required">*</text></text><input class="input" type="digit" placeholder="请输入价格" value="{{S}}" bindinput="{{T}}"/></view><view class="form-item"><text class="label">总数量 <text class="required">*</text></text><input class="input" type="number" placeholder="请输入房间总数量" value="{{U}}" bindinput="{{V}}"/></view><view class="form-item"><text class="label">可预订数量 <text class="required">*</text></text><input class="input" type="number" placeholder="请输入可预订数量" value="{{W}}" bindinput="{{X}}"/></view><view class="form-item"><text class="label">房间面积</text><input class="input" placeholder="如：25㎡" value="{{Y}}" bindinput="{{Z}}"/></view><view class="form-item"><text class="label">床型</text><picker range="{{ab}}" bindchange="{{ac}}"><view class="picker">{{aa}}</view></picker></view><view class="form-item"><text class="label">窗户</text><picker range="{{ae}}" bindchange="{{af}}"><view class="picker">{{ad}}</view></picker></view><view class="form-item"><text class="label">早餐</text><picker range="{{ah}}" bindchange="{{ai}}"><view class="picker">{{ag}}</view></picker></view></scroll-view><view class="modal-footer"><button class="cancel-btn" bindtap="{{aj}}">取消</button><button class="confirm-btn" bindtap="{{ak}}">保存</button></view></view></view><view wx:if="{{an}}" class="modal-mask" bindtap="{{aI}}"><view class="map-modal-container" catchtap="{{aH}}"><view class="map-modal-header"><text class="map-modal-title">百度地图 - 选择酒店位置</text><text class="map-modal-close" bindtap="{{ao}}">×</text></view><view class="map-search-bar"><input class="map-search-input" placeholder="搜索地点（如：福州三坊七巷）" confirm-type="search" bindinput="{{ap}}" bindconfirm="{{aq}}" value="{{ar}}"/><button class="map-search-btn" bindtap="{{as}}">搜索</button></view><view wx:if="{{at}}" class="suggest-list"><scroll-view class="suggest-scroll" scroll-y><view wx:for="{{av}}" wx:for-item="item" wx:key="c" class="suggest-item" bindtap="{{item.d}}"><view class="suggest-name">{{item.a}}</view><view class="suggest-address">{{item.b}}</view></view></scroll-view></view><map id="mapPicker" class="map-view" latitude="{{aw}}" longitude="{{ax}}" markers="{{ay}}" show-location="{{false}}" enable-zoom="{{true}}" enable-scroll="{{true}}" bindtap="{{az}}"></map><view wx:if="{{aA}}" class="poi-panel"><view class="poi-header"><text class="poi-title">附近地址（点击选择）</text><text class="poi-close" bindtap="{{aB}}">收起</text></view><scroll-view class="poi-list" scroll-y><view wx:for="{{aC}}" wx:for-item="poi" wx:key="c" class="poi-item" bindtap="{{poi.d}}"><view class="poi-name">{{poi.a}}</view><view class="poi-address">{{poi.b}}</view></view></scroll-view></view><view wx:if="{{aD}}" class="map-selected-info"><view class="selected-title">已选位置</view><view class="selected-address">{{aE}}</view></view><view class="map-modal-footer"><button class="map-cancel-btn" bindtap="{{aF}}">取消</button><button class="map-confirm-btn" bindtap="{{aG}}">确认选择</button></view></view></view></view>