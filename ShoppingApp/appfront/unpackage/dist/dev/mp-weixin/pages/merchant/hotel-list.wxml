<view class="container"><view class="header-bar"><view class="title">酒店管理</view><button class="add-btn" bindtap="{{a}}">+ 添加酒店</button></view><view class="hotel-list"><view wx:for="{{b}}" wx:for-item="hotel" wx:key="o" class="hotel-card"><image class="hotel-cover" src="{{hotel.a}}" mode="aspectFill"></image><view class="hotel-info"><text class="hotel-name">{{hotel.b}}</text><text class="hotel-address">📍 {{hotel.c}}</text><view class="hotel-stats"><text class="star-level">{{hotel.d}}</text><text class="price">¥{{hotel.e}}/晚</text></view><view class="hotel-status-row"><text class="status-label">状态：</text><text class="{{['status-value', hotel.g]}}">{{hotel.f}}</text><button class="status-toggle-btn" bindtap="{{hotel.i}}">{{hotel.h}}</button></view><view wx:if="{{hotel.j}}" class="hotel-category"><text class="category-tag">{{hotel.k}}</text></view></view><view class="hotel-actions"><button class="edit-btn" bindtap="{{hotel.l}}">编辑</button><button class="room-btn" bindtap="{{hotel.m}}">房型管理</button><button class="delete-btn" bindtap="{{hotel.n}}">删除</button></view></view></view><view wx:if="{{c}}" class="empty-state"><text>暂无酒店，点击上方按钮添加</text></view><view wx:if="{{d}}" class="loading"><text>加载中...</text></view><view wx:if="{{e}}" class="modal-mask" bindtap="{{E}}"><view class="modal-container" catchtap="{{D}}"><view class="modal-header"><text class="modal-title">{{f}}</text><text class="modal-close" bindtap="{{g}}">×</text></view><scroll-view class="modal-body" scroll-y><view class="form-item"><text class="label">酒店名称 <text class="required">*</text></text><input class="input" placeholder="请输入酒店名称" value="{{h}}" bindinput="{{i}}"/></view><view class="form-item"><text class="label">酒店分类 <text class="required">*</text></text><picker range="{{k}}" bindchange="{{l}}"><view class="picker">{{j}}</view></picker></view><view class="form-item"><text class="label">酒店地址 <text class="required">*</text></text><view class="address-row"><input class="input address-input" placeholder="请输入详细地址" value="{{m}}" bindinput="{{n}}"/><button class="map-btn" bindtap="{{o}}">🗺️ 百度地图选点</button></view></view><view class="form-item"><text class="label">星级 <text class="required">*</text></text><view class="star-box"><text wx:for="{{p}}" wx:for-item="i" wx:key="a" class="{{['star', i.b && 'active']}}" bindtap="{{i.c}}">★</text></view></view><view class="form-item"><text class="label">价格（元/晚） <text class="required">*</text></text><input class="input" type="digit" placeholder="请输入价格" value="{{q}}" bindinput="{{r}}"/></view><view class="form-item"><text class="label">总房间数</text><input class="input" type="number" placeholder="请输入总房间数" value="{{s}}" bindinput="{{t}}"/></view><view class="form-item"><text class="label">封面图</text><view class="upload-box" bindtap="{{x}}"><image wx:if="{{v}}" src="{{w}}" class="upload-image" mode="aspectFill"></image><view wx:else class="upload-placeholder"><text class="upload-icon">+</text><text class="upload-text">点击上传</text></view></view></view><view class="form-item"><text class="label">详情图（可多张）</text><view class="detail-upload-list"><view wx:for="{{y}}" wx:for-item="img" wx:key="c" class="detail-image-item" bindtap="{{img.d}}"><image src="{{img.a}}" class="detail-image" mode="aspectFill"></image><text class="detail-delete" catchtap="{{img.b}}">×</text></view><view class="upload-btn" bindtap="{{z}}"><text class="upload-icon">+</text></view></view><text wx:if="{{A}}" class="upload-tip">提示：最多可上传9张图片，点击+号选择图片</text></view></scroll-view><view class="modal-footer"><button class="cancel-btn" bindtap="{{B}}">取消</button><button class="confirm-btn" bindtap="{{C}}">保存</button></view></view></view><view wx:if="{{F}}" class="modal-mask" bindtap="{{N}}"><view class="room-modal-container" catchtap="{{M}}"><view class="modal-header"><text class="modal-title">房型管理 - {{G}}</text><button class="add-room-btn" bindtap="{{H}}">+ 添加房型</button><text class="modal-close" bindtap="{{I}}">×</text></view><scroll-view class="modal-body" scroll-y><view class="room-list"><view wx:for="{{J}}" wx:for-item="room" wx:key="l" class="room-card"><view class="room-info"><text class="room-name">{{room.a}}</text><text class="room-desc">{{room.b}} | {{room.c}} | {{room.d}}</text><view wx:if="{{room.e}}" class="room-breakfast">🍳 {{room.f}}</view><view class="room-stats"><text class="room-price">¥{{room.g}}/晚</text><text class="room-stock">库存: {{room.h}}/{{room.i}}</text></view></view><view class="room-actions"><button class="room-edit-btn" bindtap="{{room.j}}">编辑</button><button class="room-delete-btn" bindtap="{{room.k}}">删除</button></view></view></view><view wx:if="{{K}}" class="empty-state"><text>暂无房型，点击上方按钮添加</text></view></scroll-view><view class="modal-footer"><button class="cancel-btn" bindtap="{{L}}">关闭</button></view></view></view><view wx:if="{{O}}" class="modal-mask" bindtap="{{an}}"><view class="room-form-container" catchtap="{{am}}"><view class="modal-header"><text class="modal-title">{{P}}</text><text class="modal-close" bindtap="{{Q}}">×</text></view><scroll-view class="modal-body" scroll-y><view class="form-item"><text class="label">房型名称 <text class="required">*</text></text><input class="input" placeholder="如：大床房、双床房" value="{{R}}" bindinput="{{S}}"/></view><view class="form-item"><text class="label">房间价格 <text class="required">*</text></text><input class="input" type="digit" placeholder="请输入价格" value="{{T}}" bindinput="{{U}}"/></view><view class="form-item"><text class="label">总数量 <text class="required">*</text></text><input class="input" type="number" placeholder="请输入房间总数量" value="{{V}}" bindinput="{{W}}"/></view><view class="form-item"><text class="label">可预订数量 <text class="required">*</text></text><input class="input" type="number" placeholder="请输入可预订数量" value="{{X}}" bindinput="{{Y}}"/></view><view class="form-item"><text class="label">房间面积</text><input class="input" placeholder="如：25㎡" value="{{Z}}" bindinput="{{aa}}"/></view><view class="form-item"><text class="label">床型</text><picker range="{{ac}}" bindchange="{{ad}}"><view class="picker">{{ab}}</view></picker></view><view class="form-item"><text class="label">窗户</text><picker range="{{af}}" bindchange="{{ag}}"><view class="picker">{{ae}}</view></picker></view><view class="form-item"><text class="label">早餐</text><picker range="{{ai}}" bindchange="{{aj}}"><view class="picker">{{ah}}</view></picker></view></scroll-view><view class="modal-footer"><button class="cancel-btn" bindtap="{{ak}}">取消</button><button class="confirm-btn" bindtap="{{al}}">保存</button></view></view></view><view wx:if="{{ao}}" class="modal-mask" bindtap="{{aF}}"><view class="map-modal-container" catchtap="{{aE}}"><view class="map-modal-header"><text class="map-modal-title">百度地图 - 选择酒店位置</text><text class="map-modal-close" bindtap="{{ap}}">×</text></view><view class="map-tip"><text class="map-tip-text">点击地图上的位置选择酒店地址</text></view><view wx:if="{{aq}}" class="suggest-list"><scroll-view class="suggest-scroll" scroll-y><view wx:for="{{ar}}" wx:for-item="item" wx:key="c" class="suggest-item" bindtap="{{item.d}}"><view class="suggest-name">{{item.a}}</view><view class="suggest-address">{{item.b}}</view></view></scroll-view></view><map id="mapPicker" class="map-view" latitude="{{as}}" longitude="{{at}}" markers="{{av}}" show-location="{{false}}" enable-zoom="{{true}}" enable-scroll="{{true}}" bindtap="{{aw}}"></map><view wx:if="{{ax}}" class="poi-panel"><view class="poi-header"><text class="poi-title">附近地址（点击选择）</text><text class="poi-close" bindtap="{{ay}}">收起</text></view><scroll-view class="poi-list" scroll-y><view wx:for="{{az}}" wx:for-item="poi" wx:key="c" class="poi-item" bindtap="{{poi.d}}"><view class="poi-name">{{poi.a}}</view><view class="poi-address">{{poi.b}}</view></view></scroll-view></view><view wx:if="{{aA}}" class="map-selected-info"><view class="selected-title">已选位置</view><view class="selected-address">{{aB}}</view></view><view class="map-modal-footer"><button class="map-cancel-btn" bindtap="{{aC}}">取消</button><button class="map-confirm-btn" bindtap="{{aD}}">确认选择</button></view></view></view></view>