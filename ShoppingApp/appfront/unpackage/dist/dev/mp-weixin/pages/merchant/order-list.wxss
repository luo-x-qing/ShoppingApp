
.container.data-v-3b6d764b {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 标签栏 */
.tabs.data-v-3b6d764b {
  display: flex;
  flex-wrap: wrap;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}
.tab.data-v-3b6d764b {
