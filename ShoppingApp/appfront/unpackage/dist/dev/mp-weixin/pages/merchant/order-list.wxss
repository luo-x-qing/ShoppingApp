/* 拒绝弹窗样式 */
.dialog-mask.data-v-3b6d764b {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.dialog-container.data-v-3b6d764b {
  width: 600rpx;
  background: #fff;
  border-radius: 30rpx;
  overflow: hidden;
}
.dialog-header.data-v-3b6d764b {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}
.dialog-title.data-v-3b6d764b {
  font-size: 34rpx;
  font-weight: bold;
