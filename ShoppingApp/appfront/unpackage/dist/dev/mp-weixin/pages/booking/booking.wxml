<view class="container data-v-d331dabb"><view class="header data-v-d331dabb"><text class="title data-v-d331dabb">酒店预订</text></view><view class="info-card data-v-d331dabb"><text class="hotel-name data-v-d331dabb">{{a}}</text><text class="price data-v-d331dabb">¥{{b}}/晚起</text></view><view class="room-selector data-v-d331dabb" bindtap="{{e}}"><view class="selector-label data-v-d331dabb"><text class="data-v-d331dabb">选择房型</text><text class="required data-v-d331dabb">*</text></view><view class="selector-value data-v-d331dabb"><text class="{{['data-v-d331dabb', d]}}">{{c}}</text><text class="arrow data-v-d331dabb">›</text></view></view><view wx:if="{{f}}" class="room-picker-mask data-v-d331dabb" bindtap="{{j}}"><view class="room-picker-container data-v-d331dabb" catchtap="{{i}}"><view class="picker-header data-v-d331dabb"><text class="picker-title data-v-d331dabb">选择房型</text><text class="close-btn data-v-d331dabb" bindtap="{{g}}">✕</text></view><scroll-view class="room-list data-v-d331dabb" scroll-y="true"><view wx:for="{{h}}" wx:for-item="room" wx:key="i" class="room-option data-v-d331dabb" bindtap="{{room.j}}"><view class="room-option-info data-v-d331dabb"><text class="room-option-name data-v-d331dabb">{{room.a}}</text><text class="room-option-desc data-v-d331dabb">{{room.b}} | {{room.c}} | {{room.d}}</text><text wx:if="{{room.e}}" class="room-option-breakfast data-v-d331dabb">🍳 {{room.f}}</text></view><view class="room-option-right data-v-d331dabb"><text class="room-option-price data-v-d331dabb">¥{{room.g}}</text><text class="room-option-unit data-v-d331dabb">/晚</text><text class="room-option-stock data-v-d331dabb">剩余{{room.h}}间</text></view></view></scroll-view></view></view><view class="form-box data-v-d331dabb"><view class="form-item data-v-d331dabb"><text class="data-v-d331dabb">入住日期</text><picker class="data-v-d331dabb" mode="date" value="{{l}}" bindchange="{{m}}"><view class="date data-v-d331dabb">{{k}}</view></picker></view><view class="form-item data-v-d331dabb"><text class="data-v-d331dabb">退房日期</text><picker class="data-v-d331dabb" mode="date" value="{{o}}" bindchange="{{p}}"><view class="date data-v-d331dabb">{{n}}</view></picker></view><view class="form-item data-v-d331dabb"><text class="data-v-d331dabb">房间数量</text><view class="room-count data-v-d331dabb"><text class="count-btn data-v-d331dabb" bindtap="{{q}}">-</text><text class="count-num data-v-d331dabb">{{r}}</text><text class="count-btn data-v-d331dabb" bindtap="{{s}}">+</text></view></view><view class="form-item data-v-d331dabb"><text class="data-v-d331dabb">入住天数</text><text class="days data-v-d331dabb">{{t}} 晚</text></view><view class="form-item data-v-d331dabb"><text class="data-v-d331dabb">联系电话</text><input class="phone-input data-v-d331dabb" placeholder="请输入手机号" type="number" maxlength="11" value="{{v}}" bindinput="{{w}}"/></view><view class="form-item data-v-d331dabb"><text class="data-v-d331dabb">总价</text><text class="total-price data-v-d331dabb">¥{{x}}</text></view></view><view class="btn-box data-v-d331dabb"><button class="submit-btn data-v-d331dabb" bindtap="{{y}}">确认预订</button></view></view>