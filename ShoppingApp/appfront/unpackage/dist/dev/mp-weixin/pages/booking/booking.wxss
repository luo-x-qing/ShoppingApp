
page.data-v-d331dabb {
  background: #f5f5f5;
  margin: 0;
  padding: 0;
}
.container.data-v-d331dabb {
  width: 100%;
  box-sizing: border-box;
  padding-bottom: 40rpx;
}
.header.data-v-d331dabb {
  background: linear-gradient(135deg, #1677ff, #0050b3);
  padding: 40rpx 0;
  text-align: center;
}
.header .title.data-v-d331dabb {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

/* 酒店信息卡片 */
.info-card.data-v-d331dabb {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.hotel-name.data-v-d331dabb {
  font-size: 34rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
  color: #333;
}
.price.data-v-d331dabb {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: bold;
  display: block;
}

/* 房型选择器 */
.room-selector.data-v-d331dabb {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.selector-label.data-v-d331dabb {
  font-size: 28rpx;
  color: #333;
}
.required.data-v-d331dabb {
  color: #ff4d4f;
  margin-left: 4rpx;
}
.selector-value.data-v-d331dabb {
  display: flex;
  align-items: center;
  color: #999;
}
.selector-value .selected.data-v-d331dabb {
  color: #1677ff;
  font-weight: bold;
}
.selector-value .placeholder.data-v-d331dabb {
  color: #999;
}
.arrow.data-v-d331dabb {
  margin-left: 10rpx;
  font-size: 32rpx;
  color: #ccc;
}

/* 房型选择弹窗 */
.room-picker-mask.data-v-d331dabb {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.room-picker-container.data-v-d331dabb {
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  height: 60vh;
  display: flex;
  flex-direction: column;
}
.picker-header.data-v-d331dabb {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}
.picker-title.data-v-d331dabb {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}
.close-btn.data-v-d331dabb {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}
.room-list.data-v-d331dabb {
  flex: 1;
  padding: 20rpx 30rpx;
}
.room-option.data-v-d331dabb {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.room-option-info.data-v-d331dabb {
  flex: 1;
}
.room-option-name.data-v-d331dabb {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}
.room-option-desc.data-v-d331dabb {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
}
.room-option-breakfast.data-v-d331dabb {
  font-size: 22rpx;
  color: #52c41a;
}
.room-option-right.data-v-d331dabb {
  text-align: right;
}
.room-option-price.data-v-d331dabb {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b35;
}
.room-option-unit.data-v-d331dabb {
  font-size: 22rpx;
  color: #999;
}
.room-option-stock.data-v-d331dabb {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 6rpx;
}

/* 表单 */
.form-box.data-v-d331dabb {
  background: #fff;
  margin: 0 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.form-item.data-v-d331dabb {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
  font-size: 28rpx;
}
.form-item.data-v-d331dabb:last-child {
  border-bottom: none;
}
.date.data-v-d331dabb {
  color: #1677ff;
}
.days.data-v-d331dabb, .total-price.data-v-d331dabb {
  color: #ff6b35;
  font-weight: bold;
}
.room-count.data-v-d331dabb {
  display: flex;
  align-items: center;
  gap: 30rpx;
}
.count-btn.data-v-d331dabb {
  width: 50rpx;
  height: 50rpx;
  background: #f5f5f5;
  border-radius: 50%;
  text-align: center;
  line-height: 50rpx;
  font-size: 36rpx;
  color: #1677ff;
}
.count-num.data-v-d331dabb {
  font-size: 30rpx;
  font-weight: bold;
  min-width: 50rpx;
  text-align: center;
}
.phone-input.data-v-d331dabb {
  text-align: right;
  color: #333;
  flex: 1;
}
.btn-box.data-v-d331dabb {
  padding: 40rpx 20rpx;
}
.submit-btn.data-v-d331dabb {
  width: 100%;
  background: linear-gradient(135deg, #1677ff, #0050b3);
  color: #fff;
  border-radius: 44rpx;
  padding: 25rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}
