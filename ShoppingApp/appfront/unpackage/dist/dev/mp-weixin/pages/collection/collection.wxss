
page.data-v-cd17183b {
  background: #f5f5f5;
  margin: 0;
  padding: 0;
}
.container.data-v-cd17183b {
  width: 100%;
  box-sizing: border-box;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 顶部标题栏（和个人中心、酒店页面统一） */
.header.data-v-cd17183b {
  background: #fff;
  padding: 25rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

/* 标签栏 */
.tab-bar.data-v-cd17183b {
  display: flex;
  background: #fff;
  margin-bottom: 20rpx;
}
.tab-item.data-v-cd17183b {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  position: relative;
}
.tab-item.active.data-v-cd17183b {
  color: #1677ff;
  font-weight: bold;
}
.tab-item.active.data-v-cd17183b::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #1677ff;
  border-radius: 2rpx;
}

/* 列表 */
.list-content.data-v-cd17183b {
  padding: 0 20rpx 20rpx;
}
.item-card.data-v-cd17183b {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.item-img.data-v-cd17183b {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}
.item-info.data-v-cd17183b {
  flex: 1;
}
.item-name.data-v-cd17183b {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  color: #333;
}
.item-price.data-v-cd17183b {
  font-size: 24rpx;
  color: #ff6b35;
  margin-top: 6rpx;
}
.del-btn.data-v-cd17183b {
  color: #1677ff;
  font-size: 26rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  background: #fff0f0;
}
.empty.data-v-cd17183b {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
