  height: 72rpx;
  background-color: #f5f7fa;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}
.comment-submit.data-v-5fe9fe45 {
  width: 120rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 36rpx;
  font-size: 26rpx;
  border: none;
}
.commented-tip.data-v-5fe9fe45 {
  margin-top: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
  font-size: 24rpx;
  color: #52c41a;
}

/* 状态颜色 */
.status-pending.data-v-5fe9fe45 { background: #fff7e6; color: #fa8c16;
}
.status-wait-confirm.data-v-5fe9fe45 { background: #e6f7ff; color: #1677ff;
}
.status-paid.data-v-5fe9fe45 { background: #e6f7ff; color: #1677ff;
}
.status-confirmed.data-v-5fe9fe45 { background: #f6ffed; color: #52c41a;
}
.status-checkin.data-v-5fe9fe45 { background: #e6fffb; color: #13c2c2;
}
.status-completed.data-v-5fe9fe45 { background: #f0f0f0; color: #666;
}
.status-cancelled.data-v-5fe9fe45 { background: #fff1f0; color: #ff4d4f;
}
.status-cancelling.data-v-5fe9fe45 { background: #fff7e6; color: #fa8c16;
}
.status-rejected.data-v-5fe9fe45 { background: #fff1f0; color: #ff4d4f;
}
.status-default.data-v-5fe9fe45 { background: #f0f0f0; color: #666;
}

/* 空状态 */
.empty-box.data-v-5fe9fe45 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
