}
.pay-amount.data-v-5fe9fe45 {
  text-align: center;
  margin-bottom: 40rpx;
}
.amount-label.data-v-5fe9fe45 {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}
.amount-value.data-v-5fe9fe45 {
  font-size: 56rpx;
  font-weight: bold;
