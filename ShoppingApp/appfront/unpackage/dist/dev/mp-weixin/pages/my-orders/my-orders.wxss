  border-radius: 24rpx;
}
.empty-icon.data-v-5fe9fe45 {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
.empty-text.data-v-5fe9fe45 {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}
.empty-hint.data-v-5fe9fe45 {
  font-size: 24rpx;
  color: #ccc;
}

/* 弹窗样式 */
.modal-mask.data-v-5fe9fe45 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-container.data-v-5fe9fe45 {
  width: 85%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 32rpx;
  overflow: hidden;
}
.modal-header.data-v-5fe9fe45 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}
.modal-title.data-v-5fe9fe45 {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}
.modal-close.data-v-5fe9fe45 {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}
.modal-body.data-v-5fe9fe45 {
  padding: 32rpx;
}
.modal-footer.data-v-5fe9fe45 {
  display: flex;
  padding: 20rpx 32rpx 40rpx;
  gap: 20rpx;
}
.cancel-btn.data-v-5fe9fe45, .confirm-btn.data-v-5fe9fe45 {
  flex: 1;
  border-radius: 50rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: none;
}
.cancel-btn.data-v-5fe9fe45 {
  background-color: #f5f5f5;
  color: #666;
}
.confirm-btn.data-v-5fe9fe45 {
  background: linear-gradient(135deg, #1677ff, #0050b3);
  color: #fff;
}
.confirm-btn[disabled].data-v-5fe9fe45 {
