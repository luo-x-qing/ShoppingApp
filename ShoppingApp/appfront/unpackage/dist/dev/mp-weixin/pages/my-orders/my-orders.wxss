
page.data-v-5fe9fe45 {
  background-color: #f5f7fa;
}
.container.data-v-5fe9fe45 {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 40rpx;
}

/* 顶部切换标签 */
.tabs.data-v-5fe9fe45 {
  display: flex;
  background: #fff;
  border-radius: 60rpx;
  margin-bottom: 24rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.tab.data-v-5fe9fe45 {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 52rpx;
  transition: all 0.3s;
}
.tab-icon.data-v-5fe9fe45 {
  font-size: 32rpx;
}
.tab.active.data-v-5fe9fe45 {
  background: linear-gradient(135deg, #1677ff, #0050b3);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.3);
}

/* 状态筛选栏 */
.status-filter.data-v-5fe9fe45 {
  background: #fff;
  border-radius: 24rpx;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.filter-scroll.data-v-5fe9fe45 {
  white-space: nowrap;
}
.filter-items.data-v-5fe9fe45 {
  display: inline-flex;
  padding: 0 20rpx;
  gap: 16rpx;
}
.filter-item.data-v-5fe9fe45 {
  display: inline-block;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f5f7fa;
  border-radius: 40rpx;
  transition: all 0.3s;
}
.filter-item.active.data-v-5fe9fe45 {
  background: linear-gradient(135deg, #1677ff, #0050b3);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(22, 119, 255, 0.3);
}

/* 统计卡片 */
.stats-card.data-v-5fe9fe45 {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.stat-item.data-v-5fe9fe45 {
  flex: 1;
  text-align: center;
}
.stat-value.data-v-5fe9fe45 {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #1677ff;
}
.stat-label.data-v-5fe9fe45 {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.stat-divider.data-v-5fe9fe45 {
  width: 1rpx;
  height: 60rpx;
  background-color: #eee;
}

/* 订单卡片 */
.order-card.data-v-5fe9fe45 {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.order-card-header.data-v-5fe9fe45 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 28rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.hotel-name.data-v-5fe9fe45 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}
.order-id.data-v-5fe9fe45 {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}
.flight-info.data-v-5fe9fe45 {
  display: flex;
  flex-direction: column;
}
.flight-number.data-v-5fe9fe45 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.airline.data-v-5fe9fe45 {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
.order-status.data-v-5fe9fe45 {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 订单内容 */
.order-card-content.data-v-5fe9fe45 {
  padding: 20rpx 28rpx;
}
.info-row.data-v-5fe9fe45 {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.info-label.data-v-5fe9fe45 {
  width: 130rpx;
  font-size: 26rpx;
  color: #999;
}
.info-value.data-v-5fe9fe45 {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

/* 航线展示 */
.route-row.data-v-5fe9fe45 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 16rpx 0;
}
.city.data-v-5fe9fe45 {
  text-align: center;
}
.city-name.data-v-5fe9fe45 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}
.airport-name.data-v-5fe9fe45 {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}
.route-line.data-v-5fe9fe45 {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 20rpx;
}
.arrow-icon.data-v-5fe9fe45 {
  font-size: 28rpx;
  color: #1677ff;
}
.duration.data-v-5fe9fe45 {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 价格行 */
.price-row.data-v-5fe9fe45 {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #eee;
}
.price-label.data-v-5fe9fe45 {
  font-size: 26rpx;
  color: #999;
}
.price-value.data-v-5fe9fe45 {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
}

/* 取消/拒绝信息 */
.cancel-info.data-v-5fe9fe45, .reject-info.data-v-5fe9fe45 {
  margin: 0 28rpx 16rpx;
  padding: 16rpx;
  background-color: #fff7e6;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #fa8c16;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.reject-info.data-v-5fe9fe45 {
  background-color: #fff1f0;
  color: #ff4d4f;
}
.cancel-icon.data-v-5fe9fe45, .reject-icon.data-v-5fe9fe45 {
  font-size: 28rpx;
}

/* 操作按钮区域 */
.order-card-footer.data-v-5fe9fe45 {
  padding: 16rpx 28rpx 28rpx;
  border-top: 1rpx solid #f0f0f0;
}
.action-buttons.data-v-5fe9fe45 {
  display: flex;
  gap: 20rpx;
}
.action-buttons button.data-v-5fe9fe45 {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  margin: 0;
}
.btn-primary.data-v-5fe9fe45 {
  background: linear-gradient(135deg, #1677ff, #0050b3);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.3);
}
.btn-outline.data-v-5fe9fe45 {
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}
.btn-warning.data-v-5fe9fe45 {
  background: #fff;
  color: #fa8c16;
  border: 1rpx solid #fa8c16;
}
.btn-info.data-v-5fe9fe45 {
  background: #fff;
  color: #1677ff;
  border: 1rpx solid #1677ff;
}
.waiting-tip.data-v-5fe9fe45 {
  text-align: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 44rpx;
  font-size: 26rpx;
  color: #999;
}

/* 评价区域 */
.comment-section.data-v-5fe9fe45 {
  margin-top: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
.rating-row.data-v-5fe9fe45 {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.rating-label.data-v-5fe9fe45 {
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}
.stars.data-v-5fe9fe45 {
  display: flex;
  gap: 8rpx;
}
.star.data-v-5fe9fe45 {
  font-size: 36rpx;
  color: #e0e0e0;
}
.star.active.data-v-5fe9fe45 {
