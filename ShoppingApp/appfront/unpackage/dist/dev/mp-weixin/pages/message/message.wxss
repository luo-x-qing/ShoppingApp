.notice-avatar.data-v-4c1b26cf { background: linear-gradient(135deg, #ff9a3c, #ff6b6b); display: flex; align-items: center; justify-content: center;
}
.avatar-emoji.data-v-4c1b26cf { font-size: 48rpx;
