.merchant-chat-modal .modal-container.data-v-4c1b26cf { width: 90%; height: 80vh; background: #fff; border-radius: 30rpx; display: flex; flex-direction: column; overflow: hidden;
}
.merchant-chat-modal .modal-header.data-v-4c1b26cf { display: flex; justify-content: space-between; align-items: center; padding: 30rpx; background: linear-gradient(135deg, #1677ff, #0050b3);
}
.merchant-chat-modal .modal-title.data-v-4c1b26cf { font-size: 34rpx; font-weight: bold; color: #fff;
}
.merchant-chat-modal .modal-close.data-v-4c1b26cf { font-size: 40rpx; color: #fff; padding: 10rpx;
}

/* 聊天消息区域 */
.chat-messages.data-v-4c1b26cf { 
  flex: 1; 
