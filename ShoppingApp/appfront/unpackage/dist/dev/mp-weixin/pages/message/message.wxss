}
.message-item.data-v-4c1b26cf { margin-bottom: 30rpx; width: 100%;
}

/* 商家消息 - 左边 */
.message-left.data-v-4c1b26cf { display: flex; justify-content: flex-start; align-items: flex-start;
}
.message-left .message-avatar.data-v-4c1b26cf { margin-right: 16rpx;
}
.message-left .message-bubble.data-v-4c1b26cf { margin-left: 0;
}

/* 用户消息 - 右边 */
.message-right.data-v-4c1b26cf { 
  display: flex; 
  justify-content: flex-end; 
  align-items: flex-start; 
   transform: translateX(-40rpx);
}
.message-right .message-bubble.data-v-4c1b26cf { 
  margin-right: 8rpx;
}
.message-right .message-avatar.data-v-4c1b26cf { 
  margin-left: 0px;
}
.message-avatar.data-v-4c1b26cf { width: 70rpx; height: 70rpx; flex-shrink: 0; display: flex; align-items: center; justify-content: center;
}
.small-avatar.data-v-4c1b26cf { width: 60rpx; height: 60rpx; border-radius: 50%; background-color: #e8f4ff;
}
.user-avatar.data-v-4c1b26cf { width: 60rpx; height: 60rpx; background: linear-gradient(135deg, #1677ff, #0050b3); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #fff;
}
.message-bubble.data-v-4c1b26cf { max-width: 60%; padding: 20rpx 28rpx; border-radius: 30rpx; font-size: 28rpx; line-height: 1.5; word-wrap: break-word; white-space: pre-wrap;
}

/* 用户消息气泡（蓝色）- 右边 */
.user-bubble.data-v-4c1b26cf { background: linear-gradient(135deg, #1677ff, #0050b3); color: #fff; border-radius: 30rpx 30rpx 8rpx 30rpx;
}

/* 商家消息气泡（白色）- 左边 */
.merchant-bubble.data-v-4c1b26cf { background: #fff; color: #333; border-radius: 30rpx 30rpx 30rpx 8rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

/* 快捷回复 */
.quick-replies.data-v-4c1b26cf { padding: 15rpx 20rpx; background: #fff; border-top: 1rpx solid #eee; border-bottom: 1rpx solid #eee;
}
.quick-scroll.data-v-4c1b26cf { white-space: nowrap; display: flex;
}
.quick-reply-item.data-v-4c1b26cf { display: inline-block; padding: 12rpx 24rpx; background: #f5f5f5; border-radius: 40rpx; font-size: 24rpx; color: #1677ff; border: 1rpx solid #e0e0e0; margin-right: 20rpx;
}
.quick-reply-item.data-v-4c1b26cf:active { background: #e8f4ff;
}

/* 底部输入区域 */
.chat-input-area.data-v-4c1b26cf { display: flex; padding: 20rpx 30rpx; padding-bottom: calc(20rpx + constant(safe-area-inset-bottom)); padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid #eee; background: #fff; align-items: center; gap: 16rpx;
}
.chat-input.data-v-4c1b26cf { flex: 1; height: 70rpx; background: #f5f5f5; border-radius: 35rpx; padding: 0 25rpx; font-size: 28rpx;
}
.send-btn.data-v-4c1b26cf { width: 100rpx; height: 60rpx; background: linear-gradient(135deg, #1677ff, #0050b3); color: #fff; border-radius: 30rpx; font-size: 26rpx; display: flex; align-items: center; justify-content: center; border: none; line-height: 1; padding: 0;
}
.send-btn.data-v-4c1b26cf::after { border: none;
}
.loading-dots.data-v-4c1b26cf {
  display: inline-block;
  position: relative;
  min-width: 80rpx;
}
.loading-dots.data-v-4c1b26cf::after {
  content: '...';
  position: absolute;
  width: 40rpx;
  animation: dotPulse-4c1b26cf 1.5s infinite;
}
@keyframes dotPulse-4c1b26cf {
0% { content: '.';
}
33% { content: '..';
}
66% { content: '...';
}
100% { content: '.';
}
}
