
/* 禁止页面整体滚动 */
page.data-v-8145b772 {
  background: #f5f5f5;
  height: 100%;
  overflow: hidden;
}
.container.data-v-8145b772 { 
  width: 100%; 
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 固定头部区域 */
.header.data-v-8145b772 {
  background: #fff;
  padding: 25rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  flex-shrink: 0;
}

/* 固定筛选栏 */
.filter-bar.data-v-8145b772 {
  background: #fff;
  padding: 20rpx 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
}
.location-selector.data-v-8145b772 {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  max-width: 300rpx;
}
.location-icon.data-v-8145b772 {
  font-size: 28rpx;
}
.location-text.data-v-8145b772 {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}
.arrow-down.data-v-8145b772 {
  font-size: 20rpx;
  color: #999;
}
.sort-options.data-v-8145b772 {
  display: flex;
  gap: 30rpx;
}
.sort-item.data-v-8145b772 {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #666;
  padding: 8rpx 0;
}
.sort-item.active.data-v-8145b772 {
  color: #1677ff;
  font-weight: 500;
}
.sort-arrows.data-v-8145b772 {
  display: flex;
  flex-direction: column;
  margin-left: 4rpx;
}
.arrow-up.data-v-8145b772, .arrow-down-sort.data-v-8145b772 {
  font-size: 16rpx;
  line-height: 1;
  color: #ccc;
}
.arrow-up.active.data-v-8145b772, .arrow-down-sort.active.data-v-8145b772 {
  color: #1677ff;
}

/* 搜索区域 - 带下拉建议 */
.search-box.data-v-8145b772 {
  background: #fff;
  flex-shrink: 0;
  position: relative;
  z-index: 100;
}
.search-input-wrapper.data-v-8145b772 {
  display: flex;
  padding: 20rpx;
}
.search-input.data-v-8145b772 {
  flex: 1;
  height: 70rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx 0 0 8rpx;
  padding-left: 20rpx;
  font-size: 28rpx;
}
.search-btn.data-v-8145b772 {
  height: 70rpx;
  background: #1677ff;
  color: #fff;
  border: none;
  padding: 0 25rpx;
  font-size: 28rpx;
  border-radius: 0 8rpx 8rpx 0;
}

/* 搜索建议下拉列表 */
.suggest-dropdown.data-v-8145b772 {
  position: absolute;
  top: 110rpx;
  left: 20rpx;
  right: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 200;
  max-height: 500rpx;
  overflow-y: auto;
}
.suggest-item-dropdown.data-v-8145b772 {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.suggest-item-dropdown.data-v-8145b772:active {
  background-color: #f5f5f5;
}
.suggest-name.data-v-8145b772 {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
}
.suggest-info.data-v-8145b772 {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}
.suggest-category.data-v-8145b772 {
  font-size: 24rpx;
  color: #999;
}
.suggest-price.data-v-8145b772 {
  font-size: 26rpx;
  color: #ff6b35;
  font-weight: bold;
}

/* 主内容区域 */
.main-wrap.data-v-8145b772 { 
  display: flex; 
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

/* 左侧菜单 */
.left-tab.data-v-8145b772 { 
  width: 220rpx; 
  background: #fff;
  flex-shrink: 0;
  overflow-y: auto;
}
.tab-item.data-v-8145b772 {
  padding: 30rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f2f2f2;
}
.tab-item.active.data-v-8145b772 {
  color: #1677ff;
  background: #f0f7ff;
  border-left: 6rpx solid #1677ff;
}

/* 右侧酒店列表 */
.right-list.data-v-8145b772 { 
  flex: 1;
  padding: 20rpx;
}
.card.data-v-8145b772 {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.card-img.data-v-8145b772 { width: 100%; height: 300rpx;
}
.card-info.data-v-8145b772 { padding: 20rpx;
}
.card-name.data-v-8145b772 { font-size: 30rpx; font-weight: bold; display: block;
}
.card-desc.data-v-8145b772 { font-size: 24rpx; color: #999; display: block; margin-top: 8rpx;
}
.distance-text.data-v-8145b772 { color: #1677ff;
}
.rating-row.data-v-8145b772 {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}
.rating-star.data-v-8145b772 { font-size: 24rpx;
}
.rating-score.data-v-8145b772 { font-size: 24rpx; color: #ff6b35; margin-left: 4rpx; font-weight: bold;
}
.card-price.data-v-8145b772 { font-size: 28rpx; color: #ff6b35; display: block; margin-top: 12rpx; font-weight: bold;
}
.empty-state.data-v-8145b772, .loading-state.data-v-8145b772 {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

