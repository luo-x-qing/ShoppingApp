<view class="container data-v-197ccafb"><view class="header data-v-197ccafb"><text class="title data-v-197ccafb">📝 填写订单</text></view><view class="flight-card data-v-197ccafb"><view class="card-title data-v-197ccafb">航班信息</view><view class="flight-row data-v-197ccafb"><text class="label data-v-197ccafb">航班号</text><text class="value data-v-197ccafb">{{a}}</text></view><view class="flight-row data-v-197ccafb"><text class="label data-v-197ccafb">航空公司</text><text class="value data-v-197ccafb">{{b}}</text></view><view class="flight-row data-v-197ccafb"><text class="label data-v-197ccafb">出发城市</text><text class="value data-v-197ccafb">{{c}}</text></view><view class="flight-row data-v-197ccafb"><text class="label data-v-197ccafb">到达城市</text><text class="value data-v-197ccafb">{{d}}</text></view><view class="flight-row data-v-197ccafb"><text class="label data-v-197ccafb">出发时间</text><text class="value data-v-197ccafb">{{e}}</text></view><view class="flight-row data-v-197ccafb"><text class="label data-v-197ccafb">到达时间</text><text class="value data-v-197ccafb">{{f}}</text></view><view class="flight-row data-v-197ccafb"><text class="label data-v-197ccafb">飞行时长</text><text class="value data-v-197ccafb">{{g}}</text></view><view class="flight-row data-v-197ccafb"><text class="label data-v-197ccafb">单价</text><text class="value price data-v-197ccafb">¥{{h}}</text></view></view><view class="passenger-card data-v-197ccafb"><view class="card-title data-v-197ccafb">乘机人信息</view><view class="form-item data-v-197ccafb"><text class="label data-v-197ccafb">乘机人数</text><picker class="data-v-197ccafb" mode="selector" range="{{j}}" bindchange="{{k}}"><view class="input-box data-v-197ccafb"><text class="data-v-197ccafb">{{i}}人</text><text class="arrow data-v-197ccafb">›</text></view></picker></view><view wx:for="{{l}}" wx:for-item="passenger" wx:key="h" class="passenger-section data-v-197ccafb"><view class="passenger-title data-v-197ccafb">乘机人{{passenger.a}}</view><view class="form-item data-v-197ccafb"><text class="label data-v-197ccafb">乘客姓名</text><input class="input-box data-v-197ccafb" placeholder="请输入真实姓名" maxlength="20" value="{{passenger.b}}" bindinput="{{passenger.c}}"/></view><view class="form-item data-v-197ccafb"><text class="label data-v-197ccafb">身份证号</text><input class="input-box data-v-197ccafb" placeholder="请输入身份证号" maxlength="18" value="{{passenger.d}}" bindinput="{{passenger.e}}"/></view><view class="form-item data-v-197ccafb"><text class="label data-v-197ccafb">联系电话</text><input class="input-box data-v-197ccafb" placeholder="请输入11位手机号" type="number" maxlength="11" value="{{passenger.f}}" bindinput="{{passenger.g}}"/></view></view><view class="form-item total-row data-v-197ccafb"><text class="label data-v-197ccafb">总票价</text><text class="input-box total-price data-v-197ccafb">¥{{m}}</text></view></view><button class="submit-btn data-v-197ccafb" bindtap="{{o}}" disabled="{{p}}">{{n}}</button></view>